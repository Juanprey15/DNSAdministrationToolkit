<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526"/>

    <!-- Text -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="White"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>

    <!-- Font Sizes -->
    <sys:Double x:Key="TitleFontSize">24</sys:Double>
    <sys:Double x:Key="HeadingFontSize">18</sys:Double>
    <sys:Double x:Key="NormalFontSize">14</sys:Double>
    <sys:Double x:Key="SmallFontSize">12</sys:Double>

</ResourceDictionary>