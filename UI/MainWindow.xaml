<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="DNS Administration Toolkit"
    Width="1400"
    Height="900"
    MinWidth="1200"
    MinHeight="800"
    WindowStartupLocation="CenterScreen"
    FontFamily="Segoe UI"
    Background="{DynamicResource WindowBackgroundBrush}"
    Foreground="{DynamicResource PrimaryTextBrush}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition/>

                    <ColumnDefinition Width="Auto"/>

                </Grid.ColumnDefinitions>

                <TextBlock
                    Margin="20,0"
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="DNS Administration Toolkit"/>

                <TextBlock
                    Grid.Column="1"
                    Margin="20"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Text="v0.1.0-alpha"/>

            </Grid>

        </Border>

        <!-- NAVIGATION -->

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">

            <ListBox
                x:Name="NavigationMenu"
                Margin="10"
                BorderThickness="0"
                Background="Transparent"
                Foreground="{DynamicResource PrimaryTextBrush}"
                FontSize="14">

                <ListBoxItem Content="🏠 Home"/>
                <ListBoxItem Content="🔍 Search"/>
                <ListBoxItem Content="🌐 Zones"/>
                <ListBoxItem Content="📊 Reports"/>
                <ListBoxItem Content="⚙ Settings"/>

            </ListBox>

        </Border>

        <!-- CONTENT -->

        <Frame
            x:Name="MainFrame"
            Grid.Row="1"
            Grid.Column="1"
            NavigationUIVisibility="Hidden"
            Background="{DynamicResource WindowBackgroundBrush}"/>

        <!-- STATUS BAR -->

        <!-- STATUS BAR -->

        <StatusBar
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="{DynamicResource PanelBackgroundBrush}">

            <StatusBarItem>

                <TextBlock
                    x:Name="StatusText"
                    Text="Ready"
                    Foreground="{DynamicResource PrimaryTextBrush}"/>

            </StatusBarItem>

            <Separator/>

            <StatusBarItem HorizontalAlignment="Right">

                <TextBlock
                    Text="Developed by Juan Pablo Rey"
                    Foreground="{DynamicResource PrimaryTextBrush}"/>

            </StatusBarItem>

        </StatusBar>

    </Grid>

</Window>
