<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="DarkBlue">

    <Grid Margin="40">

        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBlock
                Text="DNS Administration Toolkit"
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="White"
                HorizontalAlignment="Center"/>

            <TextBlock
                Margin="0,10,0,0"
                Text="Modern DNS Administration for Microsoft Active Directory"
                FontSize="16"
                Foreground="White"
                HorizontalAlignment="Center"/>

            <Separator Margin="0,30"/>

            <TextBlock
                Text="Welcome"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="White"/>

            <TextBlock
                Margin="0,15,0,0"
                TextWrapping="Wrap"
                Width="600"
                Foreground="White"
                Text="Welcome to DAT.

This application provides a modern interface for Microsoft DNS administration.

Use the navigation menu to access DNS Search, Zone Explorer, Reverse Lookup, Reports and Settings."/>

        </StackPanel>

    </Grid>

</Page>